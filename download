<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>T-League — Скачать приложение</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@300;400;600;700;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --green:#7be856;
  --green2:#4caf50;
  --dark:#080f09;
  --dark2:#0b1a0d;
  --card:rgba(12,24,14,.95);
  --sub:#8abf90;
}
html,body{background:var(--dark);color:#fff;font-family:'Nunito',sans-serif;min-height:100vh;overflow-x:hidden;}

/* BG */
.bg{position:fixed;inset:0;z-index:0;pointer-events:none;
  background:linear-gradient(160deg,#080f09 0%,#0b1a0d 40%,#091408 100%);
}
.bg-glow{position:fixed;inset:0;z-index:0;pointer-events:none;
  background:
    radial-gradient(ellipse 70% 50% at 20% 10%,rgba(123,232,86,.07) 0%,transparent 60%),
    radial-gradient(ellipse 50% 40% at 80% 80%,rgba(76,175,80,.05) 0%,transparent 60%);
}
.bg-grid{position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:linear-gradient(rgba(123,232,86,.03) 1px,transparent 1px),
    linear-gradient(90deg,rgba(123,232,86,.03) 1px,transparent 1px);
  background-size:50px 50px;
  mask-image:radial-gradient(ellipse 90% 90% at 50% 50%,black,transparent);
}

/* HEADER */
header{position:relative;z-index:10;display:flex;align-items:center;justify-content:space-between;padding:18px 40px;border-bottom:1px solid rgba(123,232,86,.08);}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.logo img{width:36px;height:36px;border-radius:50%;border:2px solid var(--green);box-shadow:0 0 12px rgba(123,232,86,.4);}
.logo-name{font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:2px;
  background:linear-gradient(135deg,#fff,var(--green));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.header-back{color:var(--sub);font-size:13px;font-weight:600;text-decoration:none;
  display:flex;align-items:center;gap:6px;padding:8px 16px;border-radius:30px;
  background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);transition:.2s;}
.header-back:hover{background:rgba(255,255,255,.08);}

/* HERO */
.hero{position:relative;z-index:10;text-align:center;padding:70px 24px 40px;}
.hero-eyebrow{display:inline-flex;align-items:center;gap:8px;
  background:rgba(123,232,86,.08);border:1px solid rgba(123,232,86,.2);
  border-radius:50px;padding:6px 18px;font-size:12px;font-weight:700;
  color:var(--green);letter-spacing:1px;text-transform:uppercase;margin-bottom:24px;
  animation:fadeUp .6s ease both;}
.hero h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(52px,10vw,96px);
  line-height:.95;letter-spacing:3px;margin-bottom:16px;
  animation:fadeUp .6s ease .1s both;}
.hero h1 span{background:linear-gradient(135deg,#fff 0%,#c8f7a0 40%,var(--green) 70%,#fff 100%);
  background-size:200%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;
  animation:shimmer 4s linear infinite;}
.hero-sub{font-size:16px;color:var(--sub);font-weight:400;margin-bottom:48px;
  max-width:480px;margin-left:auto;margin-right:auto;line-height:1.7;
  animation:fadeUp .6s ease .2s both;}

/* DOWNLOAD BTN */
.download-btn{
  display:inline-flex;align-items:center;gap:14px;
  background:linear-gradient(135deg,var(--green),var(--green2));
  color:#0a150b;font-weight:900;font-size:18px;
  padding:18px 44px;border-radius:60px;border:none;cursor:pointer;
  box-shadow:0 8px 40px rgba(123,232,86,.5),0 2px 8px rgba(0,0,0,.4);
  text-decoration:none;transition:.25s;
  animation:fadeUp .6s ease .3s both;
  position:relative;overflow:hidden;
}
.download-btn::before{content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,.2),transparent);border-radius:60px;}
.download-btn:hover{transform:translateY(-3px) scale(1.02);box-shadow:0 12px 50px rgba(123,232,86,.65);}
.download-btn svg{width:24px;height:24px;flex-shrink:0;}
.download-hint{margin-top:14px;font-size:12px;color:rgba(255,255,255,.25);
  animation:fadeUp .6s ease .4s both;}

/* PHONE MOCKUP + SCREENSHOTS */
.screens-section{position:relative;z-index:10;padding:20px 24px 80px;}
.screens-label{text-align:center;font-size:12px;font-weight:700;color:var(--sub);
  text-transform:uppercase;letter-spacing:2px;margin-bottom:32px;}

.screens-track-wrap{overflow:hidden;position:relative;}
.screens-track{
  display:flex;gap:16px;
  animation:scrollTrack 30s linear infinite;
  width:max-content;
}
.screens-track:hover{animation-play-state:paused;}
.screen-card{
  flex-shrink:0;width:200px;
  border-radius:24px;overflow:hidden;
  border:1px solid rgba(123,232,86,.15);
  box-shadow:0 20px 40px rgba(0,0,0,.5);
  position:relative;
}
.screen-card::before{content:'';position:absolute;inset:0;z-index:1;
  background:linear-gradient(180deg,transparent 60%,rgba(8,15,9,.8) 100%);pointer-events:none;}
.screen-card img{width:100%;height:380px;object-fit:cover;object-position:top;display:block;}
.screen-notch{position:absolute;top:10px;left:50%;transform:translateX(-50%);
  width:60px;height:8px;background:rgba(0,0,0,.5);border-radius:10px;z-index:2;}

@keyframes scrollTrack{
  0%{transform:translateX(0);}
  100%{transform:translateX(-50%);}
}

/* FADE edges */
.screens-track-wrap::before,.screens-track-wrap::after{
  content:'';position:absolute;top:0;bottom:0;width:120px;z-index:2;pointer-events:none;
}
.screens-track-wrap::before{left:0;background:linear-gradient(90deg,var(--dark),transparent);}
.screens-track-wrap::after{right:0;background:linear-gradient(270deg,var(--dark),transparent);}

/* FEATURES */
.features{position:relative;z-index:10;max-width:900px;margin:0 auto;padding:0 24px 80px;}
.features h2{font-family:'Bebas Neue',sans-serif;font-size:clamp(28px,5vw,48px);
  letter-spacing:2px;text-align:center;margin-bottom:32px;color:rgba(255,255,255,.15);}
.features h2 span{color:#fff;}
.feat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px;}
.feat{background:var(--card);border:1px solid rgba(123,232,86,.1);border-radius:20px;
  padding:22px;transition:.3s;position:relative;overflow:hidden;}
.feat::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(123,232,86,.3),transparent);
  opacity:0;transition:.3s;}
.feat:hover{border-color:rgba(123,232,86,.25);transform:translateY(-3px);}
.feat:hover::after{opacity:1;}
.feat-icon{font-size:32px;margin-bottom:10px;display:block;}
.feat-title{font-size:15px;font-weight:800;margin-bottom:6px;}
.feat-desc{font-size:12px;color:var(--sub);line-height:1.6;}

/* BOTTOM CTA */
.bottom-cta{position:relative;z-index:10;text-align:center;padding:0 24px 100px;}
.bottom-cta h2{font-family:'Bebas Neue',sans-serif;font-size:clamp(32px,6vw,60px);
  letter-spacing:2px;margin-bottom:10px;}
.bottom-cta p{font-size:14px;color:var(--sub);margin-bottom:32px;}

/* FOOTER */
footer{position:relative;z-index:10;text-align:center;padding:20px 24px;
  border-top:1px solid rgba(123,232,86,.06);font-size:12px;color:rgba(255,255,255,.2);}
footer a{color:var(--green);text-decoration:none;opacity:.7;}

/* ANIMS */
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes shimmer{0%{background-position:200% center}100%{background-position:-200% center}}

.reveal{opacity:0;transform:translateY(24px);transition:opacity .7s ease,transform .7s ease;}
.reveal.visible{opacity:1;transform:translateY(0);}

/* MOBILE */
@media(max-width:600px){
  header{padding:14px 20px;}
  .hero{padding:50px 20px 30px;}
  .download-btn{font-size:16px;padding:16px 32px;}
  .screen-card{width:160px;}
  .screen-card img{height:300px;}
}
</style>
</head>
